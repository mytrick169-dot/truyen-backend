# Sao chép file này thành .env và điền thông tin thật vào

# --- Cách 1: Dùng DATABASE_URL (Aiven cấp, dán thẳng vào đây) ---
# DATABASE_URL=mysql://user:password@host:port/dbname

# --- Cách 2: Dùng từng biến riêng lẻ ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=truyen_db
DB_PORT=3306
DB_SSL=false

# Server
PORT=5000
